# Copy this to .env and fill in real values
# On Railway, set these as environment variables in the dashboard

PORT=5001
NODE_ENV=production

# MongoDB Atlas
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/webflow-builder?retryWrites=true&w=majority

# JWT
JWT_SECRET=generate-a-long-random-string-here

# Frontend URL (for CORS) — set to your Cloudflare Pages domain
FRONTEND_URL=https://genesis.spotqeys.com

# Claude AI
CLAUDE_API_KEY=sk-ant-api03-...

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_live_...

# Cloudflare (for site deployments)
CLOUDFLARE_API_TOKEN=...
CLOUDFLARE_ACCOUNT_ID=...
GENESIS_BASE_DOMAIN=pages.dev
GENESIS_ENV=prod
HOSTING_PROVIDER=cloudflare

# Airtable — single shared API key for the whole workspace.
# Per-client baseId + table names are stored on each Client record in Mongo.
AIRTABLE_API_KEY=your-airtable-api-key
